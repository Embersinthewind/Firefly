---
import type { GetStaticPaths } from "astro";
import ArticleLibrary from "@/components/articles/ArticleLibrary.astro";
import Pagination from "@/components/common/Pagination.astro";
import { siteConfig } from "@/config";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getSortedPosts } from "@/utils/content-utils";

export const getStaticPaths = (async ({ paginate }) => {
	const posts = await getSortedPosts();
	return paginate(posts, {
		pageSize: siteConfig.pagination.postsPerPage,
	});
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<MainGridLayout title="文章列表" description="浏览全部文章" contentOnly={true} showCategoryBar={true}>
	<ArticleLibrary posts={page.data} total={page.total} />
	{
		page.total > page.size && (
			<Pagination class="mx-auto onload-animation" page={page} />
		)
	}
</MainGridLayout>
