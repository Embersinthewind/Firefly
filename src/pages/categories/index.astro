---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCategoryList } from "@/utils/content-utils";

const categories = await getCategoryList();
const totalPosts = categories.reduce(
	(sum, category) => sum + category.count,
	0,
);
---

<MainGridLayout title="分类" description={`共 ${categories.length} 个分类`}>
	<section class="category-directory card-base" aria-labelledby="category-directory-title">
		<header>
			<p>Categories</p>
			<h1 id="category-directory-title">分类</h1>
			<span>{categories.length} 个分类 · {totalPosts} 篇文章</span>
		</header>

		{
			categories.length > 0 ? (
				<div class="category-directory__grid">
					{categories.map((category) => (
						<a href={category.url} class="category-directory__item">
							<span class="category-directory__icon">
								<Icon is:inline name="material-symbols:folder-open-rounded" />
							</span>
							<span class="category-directory__copy">
								<strong>{category.name}</strong>
								<small>{category.count} 篇文章</small>
							</span>
							<Icon is:inline name="material-symbols:chevron-right-rounded" class="category-directory__arrow" />
						</a>
					))}
				</div>
			) : (
				<div class="category-directory__empty">
					<Icon is:inline name="material-symbols:folder-off-outline-rounded" />
					<p>发布文章并填写分类后，这里会自动生成目录。</p>
				</div>
			)
		}
	</section>
</MainGridLayout>

<style>
	.category-directory {
		padding: 1.5rem;
	}

	.category-directory header {
		padding: 0 0.25rem 1.25rem;
		border-bottom: 1px solid var(--line-divider);
	}

	.category-directory header p {
		margin: 0 0 0.15rem;
		color: var(--primary);
		font-size: 0.78rem;
		font-weight: 750;
	}

	.category-directory h1 {
		margin: 0;
		color: var(--deep-text);
		font-size: 1.65rem;
		line-height: 1.25;
		letter-spacing: -0.025em;
	}

	.category-directory header span {
		display: block;
		margin-top: 0.35rem;
		color: var(--content-meta);
		font-size: 0.875rem;
	}

	.category-directory__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		column-gap: 2rem;
		padding-top: 0.5rem;
	}

	.category-directory__item {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		min-width: 0;
		min-height: 5.6rem;
		padding: 1rem 0.25rem;
		border-bottom: 1px solid var(--line-divider);
		color: var(--deep-text);
		transition: color 180ms ease-out, transform 180ms ease-out;
	}

	.category-directory__item:hover {
		color: var(--primary);
		transform: translateX(2px);
	}

	.category-directory__icon {
		display: grid;
		place-items: center;
		width: 2.8rem;
		height: 2.8rem;
		flex: 0 0 auto;
		border-radius: 50%;
		background: var(--btn-regular-bg);
		color: var(--btn-content);
		font-size: 1.3rem;
	}

	.category-directory__copy {
		display: flex;
		min-width: 0;
		flex: 1;
		flex-direction: column;
		gap: 0.2rem;
	}

	.category-directory__copy strong {
		overflow: hidden;
		font-size: 1rem;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.category-directory__copy small {
		color: var(--content-meta);
		font-size: 0.78rem;
	}

	.category-directory__arrow {
		flex: 0 0 auto;
		color: var(--content-meta);
		font-size: 1.25rem;
	}

	.category-directory__empty {
		display: grid;
		place-items: center;
		min-height: 15rem;
		color: var(--content-meta);
		text-align: center;
	}

	.category-directory__empty :global(svg) {
		font-size: 2.4rem;
	}

	@media (max-width: 720px) {
		.category-directory {
			padding: 1.1rem;
		}

		.category-directory__grid {
			grid-template-columns: 1fr;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.category-directory__item {
			transition: none;
		}

		.category-directory__item:hover {
			transform: none;
		}
	}
</style>
