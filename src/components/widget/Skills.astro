---
import { Icon } from "astro-icon/components";
import WidgetLayout from "@/components/common/WidgetLayout.astro";
import { portfolioConfig } from "@/config";
import type { WidgetComponentConfig } from "@/types/config";

interface Props {
	class?: string;
	style?: string;
	widgetConfig?: WidgetComponentConfig;
}

const { class: className, style, widgetConfig } = Astro.props;
---

<WidgetLayout
	name="能力矩阵"
	showTitle={widgetConfig?.showTitle !== false}
	id="skills"
	class={className}
	style={style}
>
	<div class="skills-widget">
		{
			portfolioConfig.skills.map((skill) => (
				<div class="skills-widget__item" title={skill.name}>
					<Icon is:inline name={skill.icon} />
					<span>{skill.name}</span>
				</div>
			))
		}
	</div>
</WidgetLayout>

<style>
	.skills-widget {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.55rem;
	}

	.skills-widget__item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		min-width: 0;
		padding: 0.55rem 0.6rem;
		border-radius: 0.55rem;
		background: var(--btn-regular-bg);
		color: var(--deep-text);
	}

	.skills-widget__item :global(svg) {
		width: 1rem;
		height: 1rem;
		flex: 0 0 auto;
		color: var(--primary);
	}

	.skills-widget__item span {
		overflow: hidden;
		font-size: 0.72rem;
		font-weight: 750;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
</style>
