---
import { Icon } from "astro-icon/components";
import { portfolioConfig } from "@/config";
import GitHubProjects from "./GitHubProjects.svelte";

const { home, github } = portfolioConfig;
---

<section class="portfolio-home card-base" aria-labelledby="portfolio-title">
	<header class="portfolio-home__header">
		<div>
			<span class="portfolio-home__mark" aria-hidden="true"></span>
			<p>GITHUB / PORTFOLIO</p>
			<h2 id="portfolio-title">{home.heading}</h2>
			<div class="portfolio-home__intro">{home.intro}</div>
		</div>
		<a
			class="portfolio-home__github"
			href={`https://github.com/${github.username}`}
			target="_blank"
			rel="noreferrer"
		>
			<Icon is:inline name="fa7-brands:github" />
			<span>@{github.username}</span>
			<Icon is:inline name="material-symbols:arrow-outward-rounded" />
		</a>
	</header>

	<div class="portfolio-home__statement">
		<strong>公开代码，持续迭代。</strong>
		<span>项目说明、语言、Star 与更新时间会从 GitHub 自动同步。</span>
	</div>

	<GitHubProjects config={github} client:load />
</section>

<style>
	.portfolio-home {
		position: relative;
		overflow: hidden;
		padding: clamp(1.2rem, 3vw, 2.2rem);
		margin-bottom: 1rem;
		background: var(--card-bg);
	}

	.portfolio-home::after {
		position: absolute;
		top: -7rem;
		right: -7rem;
		width: 16rem;
		height: 16rem;
		border: 1px solid color-mix(in oklch, var(--primary) 30%, transparent);
		border-radius: 50%;
		content: "";
		pointer-events: none;
	}

	.portfolio-home__header {
		position: relative;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 2rem;
		padding-bottom: 1.5rem;
	}

	.portfolio-home__mark {
		display: block;
		width: 3.25rem;
		height: 0.3rem;
		margin-bottom: 1rem;
		border-radius: 999px;
		background: var(--primary);
	}

	.portfolio-home__header p {
		margin: 0;
		color: var(--content-meta);
		font-size: 0.72rem;
		font-weight: 850;
		letter-spacing: 0.12em;
	}

	.portfolio-home__header h2 {
		margin: 0.25rem 0 0;
		color: var(--deep-text);
		font-size: clamp(2rem, 4vw, 3.4rem);
		line-height: 1.05;
		letter-spacing: -0.035em;
		text-wrap: balance;
	}

	.portfolio-home__intro {
		max-width: 58ch;
		margin-top: 0.9rem;
		color: var(--content-meta);
		font-size: 0.92rem;
		line-height: 1.75;
		text-wrap: pretty;
	}

	.portfolio-home__github {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		min-height: 2.6rem;
		padding: 0.55rem 0.9rem;
		border-radius: 999px;
		background: var(--deep-text);
		color: var(--card-bg);
		font-size: 0.8rem;
		font-weight: 800;
		white-space: nowrap;
	}

	.portfolio-home__github:hover {
		transform: translateY(-2px);
	}

	.portfolio-home__statement {
		display: flex;
		align-items: baseline;
		gap: 0.75rem 1.2rem;
		padding: 1rem 0;
		border-block: 1px solid var(--line-divider);
		color: var(--content-meta);
		font-size: 0.8rem;
		line-height: 1.5;
	}

	.portfolio-home__statement strong {
		color: var(--deep-text);
		font-size: 0.95rem;
	}

	@media (max-width: 720px) {
		.portfolio-home__header,
		.portfolio-home__statement {
			flex-direction: column;
		}

		.portfolio-home__github {
			align-self: flex-start;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.portfolio-home__github {
			transition: none;
		}
	}
</style>
