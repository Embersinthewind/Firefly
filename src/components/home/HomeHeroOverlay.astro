---
import { portfolioConfig, profileConfig, siteConfig } from "@/config";
import { url } from "@/utils/url-utils";

const displayTitle = `${profileConfig.name || siteConfig.title}の博客`;
const intro =
	profileConfig.bio && profileConfig.bio !== "Hello, I'm Yiyu."
		? profileConfig.bio
		: "躬身入局，心为主理，行有尺度，自持本心.";
const statusEvent = portfolioConfig.statusEvent;
---

<section class="home-hero-stage" aria-label="首页介绍">
	<div class="home-hero-stage__copy">
		<p class="home-hero-stage__role">[ 个人博客 / 内容主理 ]</p>
		<h1>{displayTitle}</h1>
		<p class="home-hero-stage__motto">{intro}</p>
	</div>

	<div class="home-hero-stage__side" aria-hidden="true">
		<strong>博客</strong>
		<span>{siteConfig.title}</span>
		<i></i>
		<span>CREATIVE</span>
	</div>

	<div class="home-hero-stage__dock">
		<div>
			<strong>{profileConfig.name || siteConfig.title}？</strong>
			<span>WELCOME TO MY BLOG, ENJOY YOUR STAY!</span>
		</div>
	</div>

	{
		statusEvent.mode !== "hidden" && (
			<a
				class="home-hero-stage__status"
				href={url(statusEvent.linkUrl)}
				aria-label="查看当前状态与关于页面"
				data-hero-status
				data-mode={statusEvent.mode}
				data-timezone={statusEvent.timezone}
				data-work-start={statusEvent.workStart}
				data-work-end={statusEvent.workEnd}
				data-working-label={statusEvent.workingLabel}
				data-offwork-label={statusEvent.offworkLabel}
				data-resting-label={statusEvent.restingLabel}
				data-working-image={url("/assets/status/yinyue-working.gif")}
				data-offwork-image={url("/assets/status/yinyue-offwork.gif")}
				data-resting-image={url(profileConfig.avatar || "/favicon/favicon.ico")}
			>
				<span class="home-hero-stage__status-ring">
					<img
						src={url(profileConfig.avatar || "/favicon/favicon.ico")}
						alt=""
						data-hero-status-image
					/>
				</span>
				<span class="home-hero-stage__status-label">
					<i aria-hidden="true" />
					<b data-hero-status-label>{statusEvent.workingLabel}</b>
				</span>
			</a>
		)
	}
</section>

<style>
	.home-hero-stage {
		position: absolute;
		inset: 0;
		overflow: hidden;
		color: white;
		pointer-events: none;
	}

	.home-hero-stage::before {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at 58% 38%, rgba(255, 255, 255, 0.22), transparent 34rem),
			linear-gradient(90deg, rgba(0, 0, 0, 0.72), rgba(0, 0, 0, 0.22) 52%, rgba(0, 0, 0, 0.18));
		content: "";
	}

	.home-hero-stage::after {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
		background-size: 7.5rem 7.5rem;
		mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.55), transparent 78%);
		content: "";
	}

	.home-hero-stage__copy {
		position: absolute;
		top: 34%;
		left: max(7vw, 4rem);
		z-index: 2;
		display: flex;
		max-width: min(58rem, 72vw);
		flex-direction: column;
		align-items: flex-start;
	}

	.home-hero-stage__role {
		margin: 0 0 0.3rem;
		color: rgba(255, 255, 255, 0.86);
		font-size: clamp(1rem, 1.6vw, 1.35rem);
		font-weight: 900;
		text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
	}

	.home-hero-stage h1 {
		margin: 0;
		color: white;
		font-size: clamp(4.5rem, 11vw, 9.4rem);
		font-weight: 950;
		line-height: 0.9;
		letter-spacing: -0.035em;
		text-shadow:
			0 0 1px rgba(255, 255, 255, 0.7),
			0 16px 46px rgba(0, 0, 0, 0.55);
		text-wrap: balance;
	}

	.home-hero-stage__motto {
		max-width: 45rem;
		margin: 1.5rem 0 0;
		color: rgba(255, 255, 255, 0.82);
		font-size: clamp(1rem, 1.5vw, 1.35rem);
		font-weight: 800;
		line-height: 1.7;
		text-shadow: 0 2px 16px rgba(0, 0, 0, 0.58);
	}

	.home-hero-stage__side {
		position: absolute;
		top: 34%;
		right: max(4vw, 2rem);
		z-index: 2;
		display: grid;
		place-items: center;
		gap: 0.8rem;
		writing-mode: vertical-rl;
		text-orientation: mixed;
	}

	.home-hero-stage__side strong {
		font-size: clamp(2rem, 3.2vw, 3.2rem);
		font-weight: 950;
		text-shadow: 0 5px 16px rgba(0, 0, 0, 0.6);
	}

	.home-hero-stage__side span {
		color: rgba(255, 255, 255, 0.7);
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0.45em;
	}

	.home-hero-stage__side i {
		width: 1px;
		height: 5rem;
		background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.7), transparent);
	}

	.home-hero-stage__dock {
		position: absolute;
		right: 22rem;
		bottom: 5.4rem;
		z-index: 2;
		width: min(30rem, 44vw);
		padding: 0.75rem 1.2rem;
		border: 1px solid rgba(255, 255, 255, 0.28);
		border-radius: 0.55rem;
		background: rgba(0, 0, 0, 0.26);
		box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.28);
		text-align: center;
		backdrop-filter: blur(8px);
	}

	.home-hero-stage__dock strong,
	.home-hero-stage__dock span {
		display: block;
	}

	.home-hero-stage__dock strong {
		font-size: 1.05rem;
		font-weight: 950;
	}

	.home-hero-stage__dock span {
		margin-top: 0.2rem;
		color: rgba(255, 255, 255, 0.74);
		font-size: 0.72rem;
		font-weight: 900;
	}

	.home-hero-stage__status {
		position: absolute;
		right: 5rem;
		bottom: 3.2rem;
		z-index: 3;
		display: flex;
		align-items: center;
		flex-direction: column;
		width: 7.5rem;
		color: black;
		pointer-events: auto;
		transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.home-hero-stage__status:hover {
		transform: translateY(-0.25rem);
	}

	.home-hero-stage__status-ring {
		display: block;
		width: 7.1rem;
		height: 7.1rem;
		padding: 0.28rem;
		border: 3px solid rgba(255, 255, 255, 0.95);
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.34);
		box-shadow: 0 4px 8px rgba(0, 0, 0, 0.38);
	}

	.home-hero-stage__status-ring img {
		width: 100%;
		height: 100%;
		border-radius: 50%;
		object-fit: cover;
	}

	.home-hero-stage__status-label {
		display: inline-flex;
		align-items: center;
		gap: 0.38rem;
		min-height: 1.8rem;
		margin-top: -0.6rem;
		padding: 0.24rem 0.72rem;
		border: 2px solid rgba(0, 0, 0, 0.88);
		border-radius: 999px;
		background: white;
		color: black;
		font-size: 0.76rem;
		font-weight: 950;
		white-space: nowrap;
	}

	.home-hero-stage__status-label i {
		width: 0.42rem;
		height: 0.42rem;
		border-radius: 50%;
		background: #22c55e;
		box-shadow: 0 0 0 0.16rem rgba(34, 197, 94, 0.17);
	}

	.home-hero-stage__status.is-resting .home-hero-stage__status-label i {
		background: #f59e0b;
		box-shadow: 0 0 0 0.16rem rgba(245, 158, 11, 0.17);
	}

	.home-hero-stage__status.is-offwork .home-hero-stage__status-label i {
		background: #60a5fa;
		box-shadow: 0 0 0 0.16rem rgba(96, 165, 250, 0.18);
	}

	.home-hero-stage__status-label b {
		font: inherit;
	}

	@media (max-width: 1023px) {
		.home-hero-stage__copy {
			top: 28%;
			left: 1.5rem;
			max-width: calc(100vw - 3rem);
		}

		.home-hero-stage h1 {
			font-size: clamp(3.2rem, 16vw, 6rem);
		}

		.home-hero-stage__side {
			display: none;
		}

		.home-hero-stage__dock {
			right: 1.2rem;
			bottom: 4.2rem;
			left: 1.2rem;
			width: auto;
		}

		.home-hero-stage__status {
			right: 1.2rem;
			bottom: 8.8rem;
			width: 5.4rem;
		}

		.home-hero-stage__status-ring {
			width: 5rem;
			height: 5rem;
			padding: 0.2rem;
			border-width: 2px;
		}

		.home-hero-stage__status-label {
			min-height: 1.55rem;
			padding: 0.16rem 0.55rem;
			font-size: 0.66rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.home-hero-stage *,
		.home-hero-stage::before,
		.home-hero-stage::after {
			transition: none !important;
			animation: none !important;
		}
	}
</style>

<script>
	function updateHeroStatus() {
		const element = document.querySelector<HTMLElement>("[data-hero-status]");
		if (!element) return;
		const label = element.querySelector<HTMLElement>("[data-hero-status-label]");
		const image = element.querySelector<HTMLImageElement>("[data-hero-status-image]");
		const mode = element.dataset.mode || "schedule";
		let state: "working" | "offwork" | "resting" =
			mode === "working" ? "working" : mode === "offwork" ? "offwork" : "resting";

		if (mode === "schedule") {
			try {
				const parts = new Intl.DateTimeFormat("en-US", {
					hour: "2-digit",
					hour12: false,
					timeZone: element.dataset.timezone || "Asia/Shanghai",
				}).formatToParts(new Date());
				const hour = Number(parts.find((part) => part.type === "hour")?.value || 0) % 24;
				const start = Number(element.dataset.workStart || 9);
				const end = Number(element.dataset.workEnd || 18);
				const working =
					start <= end ? hour >= start && hour < end : hour >= start || hour < end;
				state = working ? "working" : "offwork";
			} catch {
				state = "offwork";
			}
		}

		element.classList.toggle("is-working", state === "working");
		element.classList.toggle("is-offwork", state === "offwork");
		element.classList.toggle("is-resting", state === "resting");
		if (label) {
			label.textContent =
				state === "working"
					? element.dataset.workingLabel || "上班中"
					: state === "offwork"
						? element.dataset.offworkLabel || "下班中"
						: element.dataset.restingLabel || "休息中";
		}
		if (image) {
			image.src =
				state === "working"
					? element.dataset.workingImage || image.src
					: state === "offwork"
						? element.dataset.offworkImage || image.src
						: element.dataset.restingImage || image.src;
		}
	}

	updateHeroStatus();
	document.addEventListener("astro:page-load", updateHeroStatus);
	document.addEventListener("swup:contentReplaced", updateHeroStatus);
	window.setInterval(updateHeroStatus, 60_000);
</script>
