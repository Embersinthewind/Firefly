---
import { Icon } from "astro-icon/components";
---

<section class="music-experience" aria-labelledby="music-page-title">
	<header class="music-heading">
		<div><span>MUSIC COLLECTION</span><h1 id="music-page-title">我的音乐</h1></div>
		<p>在旋转的唱片与声场中，重新遇见喜欢的声音。</p>
	</header>

	<div class="music-stage" data-music-page>
		<div class="music-visual" aria-hidden="true">
			<div class="music-orbit">
				{Array.from({ length: 48 }, (_, index) => <i style={`--bar-index:${index};--bar-height:${18 + ((index * 17) % 48)}px`}></i>)}
			</div>
			<div class="music-vinyl">
				<div class="music-vinyl__label">
					<Icon is:inline name="material-symbols:music-note-rounded" />
					<img data-music-cover src="" alt="" />
				</div>
			</div>
		</div>

		<div class="music-now">
			<span class="music-now__index" data-music-index>01 / 01</span>
			<h2 data-music-title>正在载入歌单</h2>
			<p data-music-artist>Firefly Music</p>
			<div class="music-progress" data-music-progress role="slider" aria-label="播放进度" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"><span data-music-progress-bar></span></div>
			<div class="music-time"><span data-music-current>0:00</span><span data-music-duration>0:00</span></div>
			<div class="music-controls">
				<button type="button" data-music-prev aria-label="上一首"><Icon is:inline name="material-symbols:skip-previous-rounded" /></button>
				<button type="button" class="music-play" data-music-play aria-label="播放"><Icon is:inline name="material-symbols:play-arrow-rounded" /></button>
				<button type="button" data-music-next aria-label="下一首"><Icon is:inline name="material-symbols:skip-next-rounded" /></button>
			</div>
			<div class="music-lyric" data-music-lyric>让音乐先开口。</div>
		</div>

		<div class="music-playlist">
			<div class="music-playlist__header"><strong>播放列表</strong><span data-music-count>0 首</span></div>
			<div class="music-playlist__items" data-music-list><p>正在连接歌单…</p></div>
		</div>
	</div>
</section>

<script is:inline>
	(function initMusicExperience() {
		if (window.__fireflyMusicPageAbort) window.__fireflyMusicPageAbort.abort();
		var controller = new AbortController();
		window.__fireflyMusicPageAbort = controller;
		var root = document.querySelector("[data-music-page]");
		var manager = window.__fireflyMusic;
		if (!root || !manager) return;
		var ui = {
			cover: root.querySelector("[data-music-cover]"),
			title: root.querySelector("[data-music-title]"),
			artist: root.querySelector("[data-music-artist]"),
			index: root.querySelector("[data-music-index]"),
			current: root.querySelector("[data-music-current]"),
			duration: root.querySelector("[data-music-duration]"),
			progress: root.querySelector("[data-music-progress]"),
			progressBar: root.querySelector("[data-music-progress-bar]"),
			play: root.querySelector("[data-music-play]"),
			prev: root.querySelector("[data-music-prev]"),
			next: root.querySelector("[data-music-next]"),
			lyric: root.querySelector("[data-music-lyric]"),
			list: root.querySelector("[data-music-list]"),
			count: root.querySelector("[data-music-count]")
		};

		function updatePlayState(isPlaying) {
			root.classList.toggle("is-playing", !!isPlaying);
			ui.play.innerHTML = isPlaying
				? '<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6 19h4V5H6zm8-14v14h4V5z"/></svg>'
				: '<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M8 5v14l11-7z"/></svg>';
			ui.play.setAttribute("aria-label", isPlaying ? "暂停" : "播放");
		}

		function updateTrack(track, index, total) {
			if (!track) return;
			ui.title.textContent = track.name || "未知歌曲";
			ui.artist.textContent = track.artist || "未知艺术家";
			ui.index.textContent = String(index + 1).padStart(2, "0") + " / " + String(total).padStart(2, "0");
			if (track.pic) {
				ui.cover.src = track.pic;
				ui.cover.style.opacity = "1";
			} else {
				ui.cover.removeAttribute("src");
				ui.cover.style.opacity = "0";
			}
			root.querySelectorAll("[data-track-index]").forEach(function(item) {
				item.classList.toggle("active", Number(item.dataset.trackIndex) === index);
			});
		}

		function renderPlaylist(playlist) {
			ui.count.textContent = playlist.length + " 首";
			ui.list.innerHTML = "";
			if (!playlist.length) {
				ui.list.innerHTML = "<p>歌单暂时不可用。</p>";
				return;
			}
			playlist.forEach(function(track, index) {
				var button = document.createElement("button");
				button.type = "button";
				button.dataset.trackIndex = String(index);
				button.innerHTML = '<span class="track-number">' + String(index + 1).padStart(2, "0") + '</span>' +
					(track.pic ? '<img src="' + track.pic.replace(/"/g, "&quot;") + '" alt="" loading="lazy">' : '<span class="track-cover-fallback">♪</span>') +
					'<span class="track-copy"><strong></strong><small></small></span><span class="track-play">▶</span>';
				button.querySelector("strong").textContent = track.name || "未知歌曲";
				button.querySelector("small").textContent = track.artist || "未知艺术家";
				button.addEventListener("click", function() { manager.playTrackByIndex(index); });
				ui.list.appendChild(button);
			});
		}

		function syncAll() {
			var state = manager.getState();
			renderPlaylist(state.playlist || []);
			updateTrack(state.track, state.currentIndex || 0, (state.playlist || []).length || 1);
			updatePlayState(state.isPlaying);
			ui.current.textContent = state.currentTimeStr || "0:00";
			ui.duration.textContent = state.durationStr || "0:00";
			ui.progressBar.style.width = (state.progress || 0) + "%";
		}

		ui.play.addEventListener("click", function() { manager.togglePlay(); });
		ui.prev.addEventListener("click", function() { manager.playPrev(); });
		ui.next.addEventListener("click", function() { manager.playNext(); });
		ui.progress.addEventListener("click", function(event) {
			var rect = ui.progress.getBoundingClientRect();
			manager.seek((event.clientX - rect.left) / rect.width);
		});
		window.addEventListener("fm:init", function(event) { renderPlaylist(event.detail.playlist || []); syncAll(); }, { signal: controller.signal });
		window.addEventListener("fm:track", function(event) { var state = manager.getState(); updateTrack(event.detail.track, event.detail.index, state.playlist.length); }, { signal: controller.signal });
		window.addEventListener("fm:play-state", function(event) { updatePlayState(event.detail.isPlaying); }, { signal: controller.signal });
		window.addEventListener("fm:time", function(event) {
			ui.current.textContent = event.detail.currentTimeStr;
			ui.duration.textContent = event.detail.durationStr;
			ui.progressBar.style.width = event.detail.progress + "%";
			ui.progress.setAttribute("aria-valuenow", String(Math.round(event.detail.progress || 0)));
		}, { signal: controller.signal });
		window.addEventListener("fm:lyrics", function(event) {
			var lines = event.detail.lyrics || [];
			ui.lyric.textContent = lines[0]?.text || "这首歌暂时没有歌词。";
		}, { signal: controller.signal });
		window.addEventListener("fm:lrc-index", function(event) {
			var state = manager.getState();
			ui.lyric.textContent = state.lyrics[event.detail.index]?.text || ui.lyric.textContent;
		}, { signal: controller.signal });

		var initial = manager.getState();
		if (initial.initialized) syncAll();
		else manager.init();
	})();
</script>

<style>
	.music-experience { margin-bottom: 1rem; }
	.music-heading { display: flex; align-items: end; justify-content: space-between; gap: 1rem; padding: .5rem .25rem 1.25rem; }
	.music-heading span { color: var(--content-meta); font-family: ui-monospace, monospace; font-size: .65rem; font-weight: 750; letter-spacing: .12em; }
	.music-heading h1 { margin: .25rem 0 0; color: var(--deep-text); font-size: 2.7rem; line-height: .95; letter-spacing: -.04em; }
	.music-heading p { max-width: 30rem; margin: 0; color: var(--content-meta); font-size: .78rem; text-align: right; }
	.music-stage { display: grid; grid-template-columns: minmax(18rem, .85fr) minmax(18rem, 1fr); gap: 1rem 2rem; min-height: 40rem; padding: 2rem; border-radius: .9rem; background: oklch(.17 .018 265); color: oklch(.96 .01 265); box-shadow: 0 6px 8px oklch(.08 .02 265 / .22); }
	.music-visual { position: relative; display: grid; place-items: center; min-height: 27rem; perspective: 900px; }
	.music-orbit { position: absolute; width: 21rem; height: 21rem; border: 1px solid oklch(.78 .08 var(--hue) / .28); border-radius: 50%; transform: rotateX(62deg) rotateZ(-8deg); }
	.music-orbit i { --angle: calc(var(--bar-index) * 7.5deg); position: absolute; top: 50%; left: 50%; width: 3px; height: var(--bar-height); border-radius: 999px; background: oklch(.78 .17 var(--hue)); opacity: .72; transform: rotate(var(--angle)) translateY(-11.2rem); transform-origin: 50% 0; animation: music-pulse 1.1s ease-in-out infinite alternate; animation-delay: calc(var(--bar-index) * -35ms); animation-play-state: paused; }
	.is-playing .music-orbit i { animation-play-state: running; }
	.music-vinyl { position: relative; display: grid; place-items: center; width: 16rem; height: 16rem; border-radius: 50%; background: radial-gradient(circle at center, oklch(.18 .01 265) 0 7%, oklch(.64 .15 var(--hue)) 7.5% 17%, oklch(.12 .01 265) 17.5% 42%, oklch(.2 .01 265) 42.5% 44%, oklch(.1 .01 265) 44.5% 100%); transform: rotateX(10deg) rotateY(-18deg); box-shadow: 1.5rem 1.2rem 0 oklch(.05 .01 265 / .42); transition: transform 220ms ease; }
	.is-playing .music-vinyl { animation: vinyl-spin 9s linear infinite; }
	.music-vinyl__label { display: grid; place-items: center; width: 5.2rem; height: 5.2rem; overflow: hidden; border-radius: 50%; background: oklch(.64 .15 var(--hue)); color: oklch(.15 .02 265); }
	.music-vinyl__label :global(svg) { width: 1.8rem; height: 1.8rem; }
	.music-vinyl__label img { position: absolute; width: 5.2rem; height: 5.2rem; border-radius: 50%; object-fit: cover; opacity: 0; }
	.music-now { display: flex; min-width: 0; flex-direction: column; justify-content: center; }
	.music-now__index { color: oklch(.72 .13 var(--hue)); font-family: ui-monospace, monospace; font-size: .72rem; font-weight: 800; }
	.music-now h2 { margin: .8rem 0 .25rem; font-size: 2rem; line-height: 1.16; letter-spacing: -.03em; text-wrap: balance; }
	.music-now > p { margin: 0; color: oklch(.75 .015 265); font-size: .85rem; }
	.music-progress { position: relative; height: 4px; margin-top: 2rem; border-radius: 999px; background: oklch(.38 .015 265); cursor: pointer; }
	.music-progress span { position: absolute; inset: 0 auto 0 0; width: 0; border-radius: inherit; background: oklch(.72 .16 var(--hue)); }
	.music-time { display: flex; justify-content: space-between; margin-top: .45rem; color: oklch(.62 .012 265); font-family: ui-monospace, monospace; font-size: .65rem; }
	.music-controls { display: flex; align-items: center; gap: .8rem; margin-top: 1.35rem; }
	.music-controls button { display: grid; place-items: center; width: 2.75rem; height: 2.75rem; border: 0; border-radius: 50%; background: oklch(.27 .018 265); color: white; cursor: pointer; transition: background-color 180ms ease, color 180ms ease, transform 180ms ease; }
	.music-controls button:hover { background: oklch(.72 .16 var(--hue)); color: oklch(.14 .02 265); transform: translateY(-2px); }
	.music-controls .music-play { width: 3.8rem; height: 3.8rem; background: oklch(.72 .16 var(--hue)); color: oklch(.14 .02 265); }
	.music-controls :global(svg) { width: 1.6rem; height: 1.6rem; }
	.music-play :global(svg), .music-play :global(svg) { width: 1.8rem; height: 1.8rem; }
	.music-lyric { min-height: 3rem; margin-top: 1.35rem; padding-top: 1rem; border-top: 1px solid oklch(.42 .015 265); color: oklch(.76 .015 265); font-size: .78rem; line-height: 1.6; }
	.music-playlist { grid-column: 1 / -1; min-width: 0; padding-top: 1.4rem; border-top: 1px solid oklch(.36 .015 265); }
	.music-playlist__header { display: flex; align-items: center; justify-content: space-between; margin-bottom: .75rem; }
	.music-playlist__header strong { font-size: .9rem; }
	.music-playlist__header span { color: oklch(.62 .012 265); font-size: .7rem; }
	.music-playlist__items { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .4rem; max-height: 16rem; overflow: auto; padding-right: .35rem; }
	.music-playlist__items p { color: oklch(.68 .012 265); font-size: .75rem; }
	.music-playlist__items :global(button) { display: grid; grid-template-columns: 1.7rem 2.7rem minmax(0, 1fr) 1.5rem; align-items: center; gap: .6rem; min-width: 0; padding: .45rem .55rem; border: 0; border-radius: .5rem; background: transparent; color: oklch(.9 .01 265); text-align: left; cursor: pointer; }
	.music-playlist__items :global(button:hover), .music-playlist__items :global(button.active) { background: oklch(.26 .018 265); }
	.music-playlist__items :global(img), .music-playlist__items :global(.track-cover-fallback) { display: grid; place-items: center; width: 2.7rem; height: 2.7rem; border-radius: .4rem; object-fit: cover; background: oklch(.3 .02 265); color: oklch(.72 .16 var(--hue)); }
	.music-playlist__items :global(.track-number) { color: oklch(.55 .012 265); font-family: ui-monospace, monospace; font-size: .65rem; }
	.music-playlist__items :global(.track-copy) { display: flex; min-width: 0; flex-direction: column; }
	.music-playlist__items :global(.track-copy strong), .music-playlist__items :global(.track-copy small) { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
	.music-playlist__items :global(.track-copy strong) { font-size: .72rem; }
	.music-playlist__items :global(.track-copy small) { color: oklch(.62 .012 265); font-size: .62rem; }
	.music-playlist__items :global(.track-play) { color: oklch(.72 .16 var(--hue)); font-size: .65rem; }
	@keyframes vinyl-spin { to { transform: rotateX(10deg) rotateY(-18deg) rotateZ(360deg); } }
	@keyframes music-pulse { from { height: 10px; opacity: .38; } to { height: var(--bar-height); opacity: .9; } }
	@media (max-width: 820px) { .music-stage { grid-template-columns: 1fr; padding: 1.25rem; } .music-visual { min-height: 22rem; } .music-playlist { grid-column: 1; } .music-playlist__items { grid-template-columns: 1fr; } }
	@media (max-width: 640px) { .music-heading { align-items: flex-start; flex-direction: column; } .music-heading h1 { font-size: 2.2rem; } .music-heading p { text-align: left; } .music-orbit { width: 17rem; height: 17rem; } .music-orbit i { transform: rotate(var(--angle)) translateY(-9rem); } .music-vinyl { width: 13rem; height: 13rem; } .music-now h2 { font-size: 1.55rem; } }
	@media (prefers-reduced-motion: reduce) { .music-orbit i, .is-playing .music-vinyl { animation: none; } }
</style>
