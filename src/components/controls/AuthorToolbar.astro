---
import { Icon } from "astro-icon/components";

interface Props {
	entryId?: string;
}

const { entryId } = Astro.props;
const normalizedEntryId = entryId
	?.replace(/\.(?:md|mdx)$/i, "")
	.split("/")
	.map((segment) => encodeURIComponent(segment))
	.join("/");
const editEntryUrl = normalizedEntryId
	? `/admin/#/collections/posts/entries/${normalizedEntryId}`
	: undefined;
---

<aside
	class="author-toolbar"
	data-author-toolbar
	data-pagefind-ignore
	hidden
	aria-label="作者快捷操作"
	aria-keyshortcuts="Control+Shift+E Meta+Shift+E"
>
	<div class="author-toolbar__heading">
		<div class="author-toolbar__title">
			<span class="author-toolbar__status" aria-hidden="true"></span>
			<span>作者模式</span>
		</div>
		<button
			type="button"
			class="author-toolbar__exit"
			data-author-mode-exit
			aria-label="退出作者模式"
			title="退出作者模式"
		>
			<Icon is:inline name="material-symbols:close-rounded" />
		</button>
	</div>

	<nav class="author-toolbar__actions" aria-label="内容管理">
		{
			editEntryUrl && (
				<a href={editEntryUrl} class="author-toolbar__action author-toolbar__action--primary">
					<Icon is:inline name="material-symbols:edit-square-outline-rounded" />
					<span>编辑当前文章</span>
				</a>
			)
		}
		<a
			href="/admin/#/collections/posts/new"
			class:list={[
				"author-toolbar__action",
				!editEntryUrl && "author-toolbar__action--primary",
			]}
		>
			<Icon is:inline name="material-symbols:add-notes-rounded" />
			<span>写新文章</span>
		</a>
		<a href="/admin/#/collections/settings/entries/site" class="author-toolbar__action">
			<Icon is:inline name="material-symbols:tune-rounded" />
			<span>网站设置</span>
		</a>
		<a href="/admin/#/collections/settings/entries/profile" class="author-toolbar__action">
			<Icon is:inline name="material-symbols:account-circle-outline" />
			<span>个人资料</span>
		</a>
	</nav>

	<p class="author-toolbar__hint">写入操作仍由 GitHub 仓库权限验证</p>
</aside>

<script>
	const AUTHOR_MODE_KEY = "firefly-author-mode";
	const AUTHOR_MODE_SETUP_KEY = "__fireflyAuthorModeSetup";

	type AuthorWindow = Window & {
		[AUTHOR_MODE_SETUP_KEY]?: boolean;
	};

	function readAuthorMode(): boolean {
		try {
			return localStorage.getItem(AUTHOR_MODE_KEY) === "true";
		} catch {
			return false;
		}
	}

	function writeAuthorMode(enabled: boolean): void {
		try {
			if (enabled) {
				localStorage.setItem(AUTHOR_MODE_KEY, "true");
			} else {
				localStorage.removeItem(AUTHOR_MODE_KEY);
			}
		} catch {
			// The toolbar remains hidden when storage is unavailable.
		}
	}

	function consumeAuthorModeQuery(): void {
		const url = new URL(window.location.href);
		const requestedMode = url.searchParams.get("author");

		if (requestedMode !== "1" && requestedMode !== "0") return;

		writeAuthorMode(requestedMode === "1");
		url.searchParams.delete("author");
		window.history.replaceState(window.history.state, "", url);
	}

	function renderAuthorMode(): void {
		const enabled = readAuthorMode();
		document.documentElement.toggleAttribute("data-author-mode", enabled);

		document.querySelectorAll<HTMLElement>("[data-author-toolbar]").forEach((toolbar) => {
			toolbar.hidden = !enabled;
		});
	}

	function initializeAuthorMode(): void {
		consumeAuthorModeQuery();
		renderAuthorMode();
	}

	const authorWindow = window as AuthorWindow;
	if (!authorWindow[AUTHOR_MODE_SETUP_KEY]) {
		authorWindow[AUTHOR_MODE_SETUP_KEY] = true;

		document.addEventListener("click", (event) => {
			const target = event.target as Element | null;
			if (!target?.closest("[data-author-mode-exit]")) return;

			writeAuthorMode(false);
			renderAuthorMode();
		});

		document.addEventListener("keydown", (event) => {
			if (!(event.ctrlKey || event.metaKey) || !event.shiftKey || event.key.toLowerCase() !== "e") {
				return;
			}

			const activeElement = document.activeElement;
			if (activeElement instanceof HTMLInputElement || activeElement instanceof HTMLTextAreaElement) {
				return;
			}

			event.preventDefault();
			writeAuthorMode(!readAuthorMode());
			renderAuthorMode();
		});

		document.addEventListener("astro:page-load", initializeAuthorMode);
		document.addEventListener("swup:contentReplaced", initializeAuthorMode);
	}

	initializeAuthorMode();
</script>

<style>
	.author-toolbar {
		position: fixed;
		left: 1rem;
		bottom: 1rem;
		z-index: 900;
		width: min(15rem, calc(100vw - 5.5rem));
		padding: 0.75rem;
		border-radius: var(--radius-large, 0.75rem);
		background: var(--card-bg);
		box-shadow: 0 4px 8px rgb(0 0 0 / 0.14);
		color: var(--deep-text);
	}

	.author-toolbar__heading,
	.author-toolbar__title,
	.author-toolbar__action {
		display: flex;
		align-items: center;
	}

	.author-toolbar__heading {
		justify-content: space-between;
		min-height: 2rem;
		margin-bottom: 0.5rem;
	}

	.author-toolbar__title {
		gap: 0.5rem;
		font-size: 0.875rem;
		font-weight: 700;
	}

	.author-toolbar__status {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background: var(--primary);
		box-shadow: 0 0 0 3px color-mix(in oklch, var(--primary) 18%, transparent);
	}

	.author-toolbar__exit {
		display: grid;
		place-items: center;
		width: 2rem;
		height: 2rem;
		border-radius: 0.5rem;
		color: color-mix(in oklch, var(--deep-text) 62%, transparent);
		transition: color 180ms ease-out, background-color 180ms ease-out;
	}

	.author-toolbar__exit:hover {
		color: var(--deep-text);
		background: var(--btn-plain-bg-hover);
	}

	.author-toolbar__exit:focus-visible,
	.author-toolbar__action:focus-visible {
		outline: 2px solid var(--primary);
		outline-offset: 2px;
	}

	.author-toolbar__actions {
		display: grid;
		gap: 0.375rem;
	}

	.author-toolbar__action {
		gap: 0.55rem;
		min-height: 2.5rem;
		padding: 0.55rem 0.7rem;
		border-radius: 0.625rem;
		background: var(--btn-regular-bg);
		color: var(--btn-content);
		font-size: 0.8125rem;
		font-weight: 650;
		line-height: 1.25;
		transition: color 180ms ease-out, background-color 180ms ease-out, transform 180ms ease-out;
	}

	.author-toolbar__action:hover {
		background: var(--btn-regular-bg-hover);
		color: var(--primary);
		transform: translateY(-1px);
	}

	.author-toolbar__action:active {
		background: var(--btn-regular-bg-active);
		transform: translateY(0);
	}

	.author-toolbar__action--primary {
		background: var(--primary);
		color: oklch(0.18 0.02 var(--hue));
	}

	.author-toolbar__action--primary:hover {
		background: color-mix(in oklch, var(--primary) 88%, white);
		color: oklch(0.16 0.02 var(--hue));
	}

	.author-toolbar__action :global(svg) {
		flex: 0 0 auto;
		font-size: 1.15rem;
	}

	.author-toolbar__hint {
		margin: 0.625rem 0 0;
		color: color-mix(in oklch, var(--deep-text) 56%, transparent);
		font-size: 0.6875rem;
		line-height: 1.4;
		text-wrap: pretty;
	}

	@media (max-width: 640px) {
		.author-toolbar {
			left: 0.75rem;
			bottom: 0.75rem;
			padding: 0.625rem;
		}

		.author-toolbar__actions {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.author-toolbar__action {
			justify-content: center;
			padding-inline: 0.5rem;
			text-align: center;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.author-toolbar__exit,
		.author-toolbar__action {
			transition: none;
		}

		.author-toolbar__action:hover {
			transform: none;
		}
	}
</style>
