---
interface Props {
	publishedDates: Date[];
}

const { publishedDates } = Astro.props;
const availableYears = Array.from(
	new Set(publishedDates.map((date) => date.getFullYear())),
).sort((a, b) => b - a);
const years =
	availableYears.length > 0 ? availableYears : [new Date().getFullYear()];

const panels = years.map((year) => {
	const counts = new Map<string, number>();
	for (const published of publishedDates) {
		if (published.getFullYear() !== year) continue;
		const key = `${published.getFullYear()}-${published.getMonth()}-${published.getDate()}`;
		counts.set(key, (counts.get(key) ?? 0) + 1);
	}
	const maxCount = Math.max(1, ...counts.values());

	const months = Array.from({ length: 12 }, (_, month) => {
		const firstDay = new Date(year, month, 1);
		const leading = (firstDay.getDay() + 6) % 7;
		const days = new Date(year, month + 1, 0).getDate();
		const cells: Array<{
			day?: number;
			date?: string;
			count: number;
			level: number;
		}> = Array.from({ length: leading }, () => ({ count: 0, level: -1 }));

		for (let day = 1; day <= days; day += 1) {
			const count = counts.get(`${year}-${month}-${day}`) ?? 0;
			cells.push({
				day,
				date: `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`,
				count,
				level: count === 0 ? 0 : Math.max(1, Math.ceil((count / maxCount) * 4)),
			});
		}

		while (cells.length < 42) cells.push({ count: 0, level: -1 });
		return { month: month + 1, cells };
	});

	return {
		year,
		months,
		postCount: Array.from(counts.values()).reduce(
			(sum, count) => sum + count,
			0,
		),
	};
});
---

<section class="writing-trajectory" data-writing-trajectory aria-labelledby="writing-trajectory-title">
	<header>
		<div>
			<strong id="writing-trajectory-title">写作轨迹</strong>
			<span>全年发布活跃度</span>
		</div>
		{
			years.length > 1 ? (
				<label>
					<span class="sr-only">选择年份</span>
					<select data-trajectory-year aria-label="选择写作轨迹年份">
						{years.map((year) => <option value={year}>{year}</option>)}
					</select>
				</label>
			) : (
				<time>{years[0]}</time>
			)
		}
	</header>

	{
		panels.map((panel, index) => (
			<div
				class="writing-trajectory__panel"
				data-trajectory-panel={panel.year}
				hidden={index !== 0}
			>
				<div class="writing-trajectory__months">
					{panel.months.map((month) => (
						<div class="writing-trajectory__month">
							<strong>{month.month}月</strong>
							<div class="writing-trajectory__cells">
								{month.cells.map((cell) =>
									cell.date ? (
										<i
											class={`level-${cell.level}`}
											title={`${cell.date} · ${cell.count} 篇文章`}
											aria-label={`${cell.date}，${cell.count} 篇文章`}
										/>
									) : (
										<i class="is-empty" aria-hidden="true" />
									),
								)}
							</div>
						</div>
					))}
				</div>
				<footer>
					<span>{panel.year} 年</span>
					<strong>{panel.postCount} 篇</strong>
				</footer>
			</div>
		))
	}
</section>

<script>
	function initializeWritingTrajectory(): void {
		document
			.querySelectorAll<HTMLElement>("[data-writing-trajectory]")
			.forEach((root) => {
				if (root.dataset.initialized === "true") return;
				root.dataset.initialized = "true";
				const select = root.querySelector<HTMLSelectElement>(
					"[data-trajectory-year]",
				);
				select?.addEventListener("change", () => {
					root
						.querySelectorAll<HTMLElement>("[data-trajectory-panel]")
						.forEach((panel) => {
							panel.hidden = panel.dataset.trajectoryPanel !== select.value;
						});
				});
			});
	}

	initializeWritingTrajectory();
	document.addEventListener("astro:page-load", initializeWritingTrajectory);
	document.addEventListener("swup:contentReplaced", initializeWritingTrajectory);
</script>

<style>
	.writing-trajectory {
		margin-top: 0.85rem;
		padding: 0.8rem;
		border: 1px solid var(--line-divider);
		border-radius: 0.7rem;
		background: var(--card-bg);
	}

	.writing-trajectory header,
	.writing-trajectory footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.6rem;
	}

	.writing-trajectory header > div {
		display: flex;
		min-width: 0;
		flex-direction: column;
		gap: 0.08rem;
	}

	.writing-trajectory header strong {
		color: var(--deep-text);
		font-size: 0.82rem;
	}

	.writing-trajectory header span,
	.writing-trajectory header time,
	.writing-trajectory select,
	.writing-trajectory footer {
		color: var(--content-meta);
		font-size: 0.62rem;
	}

	.writing-trajectory select {
		max-width: 4.4rem;
		min-height: 1.65rem;
		padding: 0.15rem 0.35rem;
		border: 1px solid var(--line-divider);
		border-radius: 0.35rem;
		background: var(--btn-regular-bg);
		outline: none;
	}

	.writing-trajectory select:focus-visible {
		border-color: var(--primary);
		box-shadow: 0 0 0 2px color-mix(in oklch, var(--primary) 24%, transparent);
	}

	.writing-trajectory__months {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.55rem 0.45rem;
		margin-top: 0.75rem;
	}

	.writing-trajectory__month {
		min-width: 0;
	}

	.writing-trajectory__month > strong {
		display: block;
		margin-bottom: 0.25rem;
		color: var(--content-meta);
		font-size: 0.56rem;
		font-weight: 750;
	}

	.writing-trajectory__cells {
		display: grid;
		grid-template-columns: repeat(7, minmax(0, 1fr));
		gap: 0.12rem;
	}

	.writing-trajectory__cells i {
		display: block;
		aspect-ratio: 1;
		border-radius: 0.12rem;
		background: var(--muted);
	}

	.writing-trajectory__cells .is-empty {
		visibility: hidden;
	}

	.writing-trajectory__cells .level-1 {
		background: color-mix(in oklch, var(--primary) 30%, var(--muted));
	}

	.writing-trajectory__cells .level-2 {
		background: color-mix(in oklch, var(--primary) 52%, var(--muted));
	}

	.writing-trajectory__cells .level-3 {
		background: color-mix(in oklch, var(--primary) 74%, var(--muted));
	}

	.writing-trajectory__cells .level-4 {
		background: var(--primary);
	}

	.writing-trajectory footer {
		margin-top: 0.65rem;
		padding-top: 0.55rem;
		border-top: 1px solid var(--line-divider);
	}

	.writing-trajectory footer strong {
		color: var(--deep-text);
		font-size: 0.66rem;
	}

	@media (max-width: 900px) {
		.writing-trajectory {
			display: none;
		}
	}
</style>
