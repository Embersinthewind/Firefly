---
import type { CollectionEntry } from "astro:content";

interface Props {
	posts: CollectionEntry<"posts">[];
}

const { posts } = Astro.props;
const years = Array.from(
	new Set(posts.map((post) => post.data.published.getFullYear())),
).sort((a, b) => b - a);

const panels = years.map((year) => {
	const counts = new Map<string, number>();
	for (const post of posts) {
		if (post.data.published.getFullYear() !== year) continue;
		const key = [
			post.data.published.getFullYear(),
			String(post.data.published.getMonth() + 1).padStart(2, "0"),
			String(post.data.published.getDate()).padStart(2, "0"),
		].join("-");
		counts.set(key, (counts.get(key) ?? 0) + 1);
	}

	const start = new Date(year, 0, 1);
	const end = new Date(year, 11, 31);
	const leading = (start.getDay() + 6) % 7;
	const cells: Array<{ date?: string; count: number; level: number }> =
		Array.from({ length: leading }, () => ({ count: 0, level: -1 }));
	const maxCount = Math.max(1, ...counts.values());

	for (
		let cursor = new Date(start);
		cursor <= end;
		cursor.setDate(cursor.getDate() + 1)
	) {
		const date = [
			cursor.getFullYear(),
			String(cursor.getMonth() + 1).padStart(2, "0"),
			String(cursor.getDate()).padStart(2, "0"),
		].join("-");
		const count = counts.get(date) ?? 0;
		const level =
			count === 0 ? 0 : Math.max(1, Math.ceil((count / maxCount) * 4));
		cells.push({ date, count, level });
	}

	return {
		year,
		cells,
		postCount: Array.from(counts.values()).reduce(
			(sum, count) => sum + count,
			0,
		),
	};
});
---

<section class="archive-heatmap" data-archive-heatmap aria-label="年度文章活跃度">
	<header>
		<div>
			<strong>写作轨迹</strong>
			<span>每一个色块代表一天，颜色越深表示发布越多。</span>
		</div>
		<div class="archive-heatmap__years" role="tablist" aria-label="选择年份">
			{
				panels.map((panel, index) => (
					<button
						type="button"
						role="tab"
						aria-selected={index === 0 ? "true" : "false"}
						data-heatmap-year={panel.year}
					>
						{panel.year}
					</button>
				))
			}
		</div>
	</header>

	<div class="archive-heatmap__viewport">
		{
			panels.map((panel, index) => (
				<div
					class="archive-heatmap__panel"
					data-heatmap-panel={panel.year}
					hidden={index !== 0}
					role="tabpanel"
				>
					<div class="archive-heatmap__months" aria-hidden="true">
						{Array.from({ length: 12 }, (_, month) => <span>{month + 1}月</span>)}
					</div>
					<div class="archive-heatmap__cells">
						{panel.cells.map((cell) =>
							cell.date ? (
								<span
									class={`archive-heatmap__cell level-${cell.level}`}
									title={`${cell.date} · ${cell.count} 篇文章`}
									aria-label={`${cell.date}，${cell.count} 篇文章`}
								/>
							) : (
								<span class="archive-heatmap__cell is-empty" aria-hidden="true" />
							),
						)}
					</div>
					<p>{panel.year} 年共发布 {panel.postCount} 篇文章</p>
				</div>
			))
		}
	</div>

	<div class="archive-heatmap__legend" aria-hidden="true">
		<span>少</span>
		<i class="level-0"></i><i class="level-1"></i><i class="level-2"></i><i class="level-3"></i><i class="level-4"></i>
		<span>多</span>
	</div>
</section>

<script>
	function initializeArchiveHeatmap(): void {
		document.querySelectorAll<HTMLElement>("[data-archive-heatmap]").forEach((root) => {
			if (root.dataset.initialized === "true") return;
			root.dataset.initialized = "true";

			root.querySelectorAll<HTMLButtonElement>("[data-heatmap-year]").forEach((button) => {
				button.addEventListener("click", () => {
					const year = button.dataset.heatmapYear;
					root.querySelectorAll<HTMLButtonElement>("[data-heatmap-year]").forEach((item) => {
						item.setAttribute("aria-selected", String(item === button));
					});
					root.querySelectorAll<HTMLElement>("[data-heatmap-panel]").forEach((panel) => {
						panel.hidden = panel.dataset.heatmapPanel !== year;
					});
				});
			});
		});
	}

	document.addEventListener("astro:page-load", initializeArchiveHeatmap);
	document.addEventListener("swup:contentReplaced", initializeArchiveHeatmap);
	initializeArchiveHeatmap();
</script>

<style>
	.archive-heatmap {
		padding: 1.1rem 1.25rem 0.9rem;
		border-bottom: 1px solid var(--line-divider);
	}

	.archive-heatmap header {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.archive-heatmap header > div:first-child {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.archive-heatmap header strong {
		color: var(--deep-text);
		font-size: 1rem;
	}

	.archive-heatmap header span,
	.archive-heatmap__panel p,
	.archive-heatmap__legend {
		color: var(--content-meta);
		font-size: 0.72rem;
	}

	.archive-heatmap__years {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.35rem;
	}

	.archive-heatmap__years button {
		min-height: 1.85rem;
		padding: 0.25rem 0.6rem;
		border-radius: 0.4rem;
		background: var(--btn-regular-bg);
		color: var(--content-meta);
		font-size: 0.72rem;
		font-weight: 700;
	}

	.archive-heatmap__years button[aria-selected="true"] {
		background: var(--primary);
		color: oklch(0.18 0.02 var(--hue));
	}

	.archive-heatmap__viewport {
		overflow-x: auto;
		padding-bottom: 0.35rem;
	}

	.archive-heatmap__panel {
		min-width: 42rem;
	}

	.archive-heatmap__months {
		display: grid;
		grid-template-columns: repeat(12, 1fr);
		margin-bottom: 0.35rem;
		color: var(--content-meta);
		font-size: 0.64rem;
	}

	.archive-heatmap__cells {
		display: grid;
		grid-auto-columns: 0.72rem;
		grid-auto-flow: column;
		grid-template-rows: repeat(7, 0.72rem);
		gap: 0.18rem;
		width: max-content;
	}

	.archive-heatmap__cell,
	.archive-heatmap__legend i {
		border-radius: 0.2rem;
		background: var(--muted);
	}

	.archive-heatmap__cell.is-empty {
		visibility: hidden;
	}

	.archive-heatmap__cell.level-1,
	.archive-heatmap__legend .level-1 { background: color-mix(in oklch, var(--primary) 30%, var(--muted)); }
	.archive-heatmap__cell.level-2,
	.archive-heatmap__legend .level-2 { background: color-mix(in oklch, var(--primary) 52%, var(--muted)); }
	.archive-heatmap__cell.level-3,
	.archive-heatmap__legend .level-3 { background: color-mix(in oklch, var(--primary) 74%, var(--muted)); }
	.archive-heatmap__cell.level-4,
	.archive-heatmap__legend .level-4 { background: var(--primary); }

	.archive-heatmap__panel p {
		margin: 0.55rem 0 0;
	}

	.archive-heatmap__legend {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.25rem;
		margin-top: 0.35rem;
	}

	.archive-heatmap__legend i {
		display: block;
		width: 0.65rem;
		height: 0.65rem;
	}

	@media (max-width: 720px) {
		.archive-heatmap header {
			align-items: flex-start;
			flex-direction: column;
		}

		.archive-heatmap__years {
			justify-content: flex-start;
		}
	}
</style>
